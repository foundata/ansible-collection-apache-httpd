{#-
  Jinja2 helper macros for Apache HTTPD configuration rendering.

  Adapted from the foundata.nginx.run role's _nginx_macros.j2, with
  Apache-specific differences:
    - No trailing semicolons on directives.
    - Booleans render as "On" / "Off" (Apache convention) instead of
      "on" / "off" (nginx convention).

  Import pattern:
    {% from '_apache_httpd_macros.j2' import render_directives %}
-#}

{%- macro render_directive(directive, value, indent=0) -%}
{%-   set rendered_directive_value = (
        'On' if value is ansible.builtin.boolean and value
        else 'Off' if value is ansible.builtin.boolean
        else (value | ansible.builtin.string | ansible.builtin.trim)
      ) -%}
{{ (directive | ansible.builtin.trim ~ ' ' ~ rendered_directive_value)
    | ansible.builtin.indent(indent, true, false) }}
{%- endmacro -%}


{%- macro render_directives(directives, indent=0) -%}
{%-   for directive, value in (directives | default({})).items() -%}
{%-     if value is ansible.builtin.sequence and value is not string -%}
{%-       for item in value -%}
{{- render_directive(directive, item, indent) -}}
{%          if not loop.last -%}
{{ '\n' }}
{%-         endif -%}
{%-       endfor -%}
{%-     else -%}
{{- render_directive(directive, value, indent) -}}
{%-     endif -%}
{%      if not loop.last -%}
{{ '\n' }}
{%-     endif -%}
{%-   endfor -%}
{%- endmacro -%}
